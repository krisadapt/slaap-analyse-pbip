	partition Gedrag = m
		mode: import
		queryGroup: FACT\Garmin
		source =
				let
				    Bron = #"Garmin Bron",
				    Content = Bron{0}[Content],
				    #"CSV-bestand geïmporteerd" = Csv.Document(Content,[Delimiter=",", Columns=8, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				    #"Headers met verhoogd niveau" = Table.PromoteHeaders(#"CSV-bestand geïmporteerd", [PromoteAllScalars=true]),
				    // aantal staat in de CSV als decimaal met punt (1.0) → eerst en-US naar number, daarna geheel getal
				    #"Type gewijzigd" = Table.TransformColumnTypes(#"Headers met verhoogd niveau",{{"datum", type date}, {"categorie", type text}, {"gedrag", type text}, {"gedrag_id", Int64.Type}, {"status", type text}, {"slaap_gerelateerd", type logical}, {"subtype", type text}, {"aantal", type number}}, "en-US"),
				    #"Aantal geheel" = Table.TransformColumnTypes(#"Type gewijzigd",{{"aantal", Int64.Type}}),
				    // Gedrag van dag X beïnvloedt de nacht met ontwaakdatum X+1 (avondgedrag → nacht erna)
				    #"Nacht toegevoegd" = Table.AddColumn(#"Aantal geheel", "Nacht", each Date.AddDays([datum], 1), type date)
				in
				    #"Nacht toegevoegd"

	annotation PBI_NavigationStepName = Navigatie

	annotation PBI_ResultType = Table

