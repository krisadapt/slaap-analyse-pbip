	/// Ontwaakdatum van de nacht die dit gedrag beïnvloedt (= gedragsdag + 1). Relatiekey naar Kalender: gedrag van de avond hoort bij de nacht erna.
	column Nacht
		dataType: dateTime
		isHidden
		formatString: Long Date
		displayFolder: _Verborgen
		lineageTag: 8c5e2d94-7a31-4f68-b9d5-3e6c8f2a7b41
