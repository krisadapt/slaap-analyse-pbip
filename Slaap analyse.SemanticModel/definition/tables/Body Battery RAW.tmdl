		annotation SummarizationSetBy = Automatic

	partition 'Body Battery RAW' = m
		mode: import
		queryGroup: FACT\Garmin
		source =
				let
				    Pad = "E:\ADAPT\04 Projecten - Documents\18 CPAP Analyse\Export\Garmin\garmin_body_battery_raw.csv",
				    Bron = Csv.Document(File.Contents(Pad),[Delimiter=",", Columns=4, Encoding=1252, QuoteStyle=QuoteStyle.None]),
				    #"Headers met verhoogd niveau" = Table.PromoteHeaders(Bron, [PromoteAllScalars=true]),
				    #"Type gewijzigd" = Table.TransformColumnTypes(#"Headers met verhoogd niveau",{{"datum", type date}, {"bb_waarde", Int64.Type}}),
				    // Extraheer uur uit tijd_utc (HH:MM) â†’ HH:00, HH:15, HH:30, HH:45
				    #"Kwartier toegevoegd" = Table.AddColumn(#"Type gewijzigd", "kwartier", each
				        let
				            uur = Text.Start([tijd_utc], 2),
				            minuut = Int64.From(Text.End([tijd_utc], 2)),
				            kwart = Number.RoundDown(minuut / 15) * 15
				        in
				            uur & ":" & Text.PadStart(Text.From(kwart), 2, "0")
				    ),
				    // Groepeer per (datum, kwartier): gemiddelde, min, max
				    #"Gegroepeerd" = Table.Group(#"Kwartier toegevoegd", {"datum", "kwartier"}, {
				        {"bb_gem", each List.Average([bb_waarde]), type number},
				        {"bb_min", each List.Min([bb_waarde]), type number},
				        {"bb_max", each List.Max([bb_waarde]), type number},
				        {"aantal_metingen", each List.Count([bb_waarde]), type number}
				    })
				in
				    #"Gegroepeerd"

	annotation PBI_NavigationStepName = Navigatie

	annotation PBI_ResultType = Table
